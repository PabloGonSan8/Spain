---
import CopyButton from "@components/CopyButton.astro";

interface Props {
  title: string;
  method: string;
  code: string;
}

const { title, method, code } = Astro.props;
---

<div>
  <h3 class="text-lg font-semibold text-white mb-2">
    {title}
  </h3>
  <div class="flex flex-wrap sm:flex-nowrap items-center gap-3 bg-white/5 px-4 py-2 rounded-lg border border-white/10">
    <span class="bg-white/80 text-green-500 font-bold px-3 py-1 rounded-md text-sm flex-shrink-0">{method}</span>
    <code class="text-yellow-300 text-sm break-all flex-1">{code}</code>
    <CopyButton text={code} />
  </div>
</div>
