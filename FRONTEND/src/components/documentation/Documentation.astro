---
import CopyButton from "@components/CopyButton.astro";

const cloneCmd = "git clone https://github.com/PabloGonSan8/Spain.git";
const dockerCmd = "docker compose up --build";
const sqlCmd = "mysql -u root -p < spain.sql";
const mvnCmd = "cd BACKEND && mvn spring-boot:run";
const apiUrl = "http://localhost:8080";
---

<section class="bg-white/10 p-6 rounded-xl border border-white/20">
  <h2 class="text-2xl font-semibold mb-6">⚙️ Cómo levantar el Backend (API)</h2>

  <div class="space-y-8 text-gray-200">

    <!-- OPCIÓN A: DOCKER -->
    <div>
      <h3 class="text-xl font-semibold text-white mb-4">
        🐳 Opción A — Docker <span class="text-sm font-normal text-green-400 ml-2">(recomendado)</span>
      </h3>

      <div class="space-y-4">
        <div>
          <p class="text-sm mb-2">Requisitos: <strong class="text-white">Docker + Docker Compose</strong></p>
        </div>

        <div>
          <p class="text-sm mb-2">1️⃣ Clona el repositorio:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{cloneCmd}</code>
            <CopyButton text={cloneCmd} />
          </div>
        </div>

        <div>
          <p class="text-sm mb-2">2️⃣ Levanta la API y la base de datos:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{dockerCmd}</code>
            <CopyButton text={dockerCmd} />
          </div>
          <p class="text-sm mt-2 text-yellow-300">
            💡 La primera vez tarda ~2-3 minutos mientras MySQL importa los datos.
          </p>
        </div>

        <div>
          <p class="text-sm mb-2">3️⃣ API disponible en:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{apiUrl}</code>
            <CopyButton text={apiUrl} />
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10"></div>

    <!-- OPCIÓN B: MANUAL -->
    <div>
      <h3 class="text-xl font-semibold text-white mb-4">
        🔧 Opción B — Manual (XAMPP / MySQL)
      </h3>

      <div class="space-y-4">
        <div>
          <p class="text-sm mb-2">
            Requisitos: <strong class="text-white">Java 17+, Maven 3.8+, MySQL 8</strong>
          </p>
        </div>

        <div>
          <p class="text-sm mb-2">1️⃣ Clona el repositorio:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{cloneCmd}</code>
            <CopyButton text={cloneCmd} />
          </div>
        </div>

        <div>
          <p class="text-sm mb-2">2️⃣ Importa la base de datos:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{sqlCmd}</code>
            <CopyButton text={sqlCmd} />
          </div>
          <p class="text-sm mt-2 text-yellow-300">
            💡 En XAMPP el usuario suele ser <strong>root</strong> sin contraseña.
          </p>
        </div>

        <div>
          <p class="text-sm mb-2">3️⃣ Ejecuta el backend:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{mvnCmd}</code>
            <CopyButton text={mvnCmd} />
          </div>
        </div>

        <div>
          <p class="text-sm mb-2">4️⃣ API disponible en:</p>
          <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-lg border border-white/10 overflow-x-auto">
            <code class="text-yellow-300 text-sm break-all flex-1">{apiUrl}</code>
            <CopyButton text={apiUrl} />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
