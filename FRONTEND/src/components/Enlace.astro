---
interface Props {
  href: string;
  icon: string;
  title: string;
  description: string;
  color?: string;
}

const { href, icon, title, description, color = 'blue-400' } = Astro.props;
---

<a
  href={href}
  class="group bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 hover:bg-white/20 transition-all duration-300 hover:scale-105"
>
  <div class={"text-" + color + " mb-4"}>
    <svg
      class="w-12 h-12 mx-auto"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d={icon}
      ></path>
    </svg>
  </div>
  <h3 class="text-xl font-semibold mb-2">{title}</h3>
  <p class="text-gray-300 text-sm">{description}</p>
</a>
